# =============================================================================
# Environment Variables Reference
# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.
#
# Credential precedence (highest → lowest):
#   1. Environment variables / .env
#   2. prefect.toml  (see prefect.toml.example)
#   3. Active profile in ~/.prefect/profiles.toml
#
# PREFECT_API_KEY and PREFECT_API_URL are optional here if you already have
# them set via a local prefect.toml or `prefect profile`.
# =============================================================================

# -----------------------------------------------------------------------------
# Prefect Cloud — optional if set in prefect.toml or active profile
# -----------------------------------------------------------------------------
# PREFECT_API_KEY=
# PREFECT_API_URL=https://api.prefect.cloud/api/accounts/${PREFECT_ACCOUNT_ID}/workspaces/${PREFECT_WORKSPACE_ID}

# -----------------------------------------------------------------------------
# Work pool — used in prefect.yaml deployments and helm/values.yaml
# -----------------------------------------------------------------------------
PREFECT_WORK_POOL_NAME=

# Docker image used by all deployments in prefect.yaml
# Build: docker buildx build --platform linux/amd64 -t <your-registry>/mm2-sandbox:$(date +%Y-%m-%d) .
PREFECT_DEPLOYMENT_IMAGE=

# -----------------------------------------------------------------------------
# Helm worker (helm/values.yaml)
# Copy helm/values.yaml to helm/values.local.yaml and substitute these values.
# Deploy: helm install prefect-worker prefect/prefect-worker -f helm/values.local.yaml
# -----------------------------------------------------------------------------
PREFECT_API_KEY_SECRET_NAME=prefect-api-key

# -----------------------------------------------------------------------------
# Python examples
# -----------------------------------------------------------------------------

# 03_task_caching.py — S3 bucket block name for result storage
S3_RESULT_BUCKET=your-bucket-name
REFRESH_CACHE=False

# 08_state_hooks.py — Prefect block name holding Slack credentials
SLACK_CREDENTIALS_BLOCK=slack-creds

# 09_automations.py — Slack incoming webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 14_flow_level_caching.py — GCS bucket block name for result storage
GCS_RESULT_BUCKET=your-gcs-bucket-block-name

# -----------------------------------------------------------------------------
# Terraform (terraform/)
# Set these before running terraform apply:
#   export TF_VAR_PREFECT_API_KEY=$PREFECT_API_KEY
#   export TF_VAR_PREFECT_ACCOUNT_ID=$PREFECT_ACCOUNT_ID
# -----------------------------------------------------------------------------
# TF_VAR_PREFECT_API_KEY=     # same as PREFECT_API_KEY above
# TF_VAR_PREFECT_ACCOUNT_ID=  # same as PREFECT_ACCOUNT_ID above
# TF_VAR_PREFECT_WORKSPACE_HANDLE=sandbox-mason
